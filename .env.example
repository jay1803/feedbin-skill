# Feedbin credentials (required)
FEEDBIN_EMAIL=you@example.com
FEEDBIN_PASSWORD=your-feedbin-password

# Optional API config
FEEDBIN_BASE_URL=https://api.feedbin.com/v2
FEEDBIN_TIMEOUT_SEC=30
FEEDBIN_MAX_RETRIES=3
FEEDBIN_RETRY_BACKOFF_SEC=0.8

# Optional archive defaults
# FEEDBIN_ARCHIVE_OUTPUT=./output
# FEEDBIN_BLACKLIST=./blacklist.txt
